# Application Settings
APP_VERSION=1.0.0
APP_NAME="Japanese Aduio"
APP_DESCRIPTION="Japanese Aduio Template"
API_PREFIX=/api

# Database Settings
# Connection String
DATABASE_URL=
TEST_DATABASE_URL=sqlite+aiosqlite:///./test_app.db

# PostgreSQL Configuration (Optional)
# Uncomment and fill these values to use PostgreSQL instead of SQLite
#DB_NAME=your_database_name
#DB_USER=your_database_user
#DB_PASSWORD=your_database_password
#DB_HOST=localhost
#DB_PORT=5432

# Database Pool Settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_ECHO=false
#DB_SSL_MODE=disable  # Options: disable, allow, prefer, require, verify-ca, verify-full

# CORS Settings
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]
FRONTEND_URL=http://localhost:5173

# Environment
ENVIRONMENT=development  # Options: development, production, testing

# JWT Settings
JWT_SECRET_KEY=
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google API Key
GOOGLE_API_KEY=

# SMTP Settings
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=yourapppassword
SMTP_FROM_NAME="PBL5 Japanese Audio"
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Cloudinary Settings
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
GOOGLE_API_KEY=

# n8n Automation
N8N_WEBHOOK_URL=

# AI Model settings
LM_STUDIO_API_URL=http://127.0.0.1:1234/v1/chat/completions
LM_STUDIO_MODEL=gemma-4-e4b-it

# AI Image Generation (Draw Things / Stable Diffusion)
DRAW_THINGS_API_URL=http://127.0.0.1:7860/sdapi/v1/txt2img
AI_PHOTO_BASE_PROMPT=
AI_PHOTO_NEGATIVE_PROMPT=
AI_PHOTO_OUTPUT_DIR=generated/ai-photos
AI_PHOTO_WIDTH=512
AI_PHOTO_HEIGHT=512
AI_PHOTO_STEPS=25
AI_PHOTO_CFG_SCALE=7.0
